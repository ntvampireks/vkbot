# Токен сообщества VK (создаётся в разделе Работа с API)
VK_GROUP_TOKEN=your_token_here

# ID сообщества (числовой, без "club" или "-" префикса)
VK_GROUP_ID=12345678

# Имя бота для проверки упоминаний
VK_BOT_NAME=Бот

# Опционально: хост и порт (не используются для LongPoll)
BOT_HOST=localhost
BOT_PORT=8000

# Опционально: таймаут сессии диалога в часах
DIALOG_TIMEOUT_HOURS=24
